# ==========================================
# Commission Tracker - Environment Variables
# ==========================================

# Commission Tracker Airtable base (your new base for commissions/splits)
VITE_AIRTABLE_API_KEY=pat...
VITE_TRACKER_BASE_ID=appXXXXXXXXXXXXXX

# CBRS shared base (multiple contractors in one base)
VITE_CBRS_BASE_ID=appXXXXXXXXXXXXXX
VITE_CBRS_API_KEY=pat...
VITE_CBRS_CONTRACTOR_FIELD=Contractor Name

# ==========================================
# DMSW and VEC do NOT go here.
# They are added via the /contractors page in the app.
# Each standalone contractor stores its own Base ID + API Key.
# ==========================================
